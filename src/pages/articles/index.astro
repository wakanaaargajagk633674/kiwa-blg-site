---
import ArticleCard from "../../components/ArticleCard";
import CTASection from "../../components/CTASection";
import FadeInSection from "../../components/FadeInSection";
import FeatureCard from "../../components/FeatureCard";
import SectionTitle from "../../components/SectionTitle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articleFromModule, sortArticles } from "../../lib/articles";
import type { ArticleModule } from "../../lib/articles";

const articleModules = import.meta.glob<ArticleModule>("../../content/articles/*.{md,mdx}", { eager: true });
const articles = sortArticles(
  Object.entries(articleModules)
    .map(([path, articleModule]) => articleFromModule(path, articleModule))
    .filter((article) => !article.draft),
);

const categories = Array.from(new Set(articles.map((article) => article.category)));

const routes = [
  {
    icon: "Workflow",
    title: "思想から読む",
    description: "AIに聞いて終わりにしないための基本方針を確認します。",
    href: "/articles/stop-asking-start-building-ai-operations/",
  },
  {
    icon: "FileText",
    title: "Prompt / Skill / Agent から読む",
    description: "AIに作業を渡すための入力、手順、権限設計を整理します。",
    href: "/articles/prompt-skill-agent-practical-difference/",
  },
  {
    icon: "Terminal",
    title: "Codex活用へ進む",
    description: "Astroサイト構築をCodexに任せた実践ログから確認します。",
    href: "/articles/codex-astro-site-build-log/",
  },
];
---

<BaseLayout
  title="Articles"
  description="AI業務改善、Codex活用、Prompt / Skill / Agent設計の実践ログ一覧。"
>
  <section class="page-hero">
    <div class="container">
      <FadeInSection client:load>
        <SectionTitle
          kicker="Articles"
          title="実践ログと設計メモ"
          text="AIを業務改善の実行基盤にするための試行錯誤、設計、比較、検証をMarkdown / MDXで管理します。"
        />
      </FadeInSection>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <FadeInSection client:visible>
        <div class="article-overview">
          <div>
            <span>Published</span>
            <strong>{articles.length}</strong>
          </div>
          <div>
            <span>Categories</span>
            <strong>{categories.join(" / ")}</strong>
          </div>
          <div>
            <span>Format</span>
            <strong>Markdown / MDX</strong>
          </div>
        </div>
      </FadeInSection>

      <div class="article-grid article-grid-spaced">
        {
          articles.map((article) => (
            <ArticleCard
              client:visible
              title={article.title}
              description={article.description}
              href={article.href}
              category={article.category}
              date={article.dateLabel}
              readTime={article.readTime}
              tags={article.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <SectionTitle
        kicker="Reading route"
        title="目的別に読む"
        text="公開直後の記事は、思想、設計、実装、保存、役割分担の順で読むと全体像をつかみやすくなります。"
      />
      <div class="feature-grid">
        {routes.map((route) => <FeatureCard client:visible {...route} />)}
      </div>
    </div>
  </section>

  <div class="container">
    <CTASection
      client:visible
      title="次はAI成果物を保存する仕組みを作る"
      text="記事を読んで終わりにせず、Prompt、Skill、Agent、Evalを保存する場所を決めると運用に戻しやすくなります。"
      primaryHref="/articles/obsidian-ai-output-reuse/"
      primaryLabel="Obsidianの記事へ"
      secondaryHref="/prompt-skill-agent/"
      secondaryLabel="入門ページへ"
    />
  </div>
</BaseLayout>
