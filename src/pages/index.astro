---
import ArticleCard from "../components/ArticleCard";
import CTASection from "../components/CTASection";
import FadeInSection from "../components/FadeInSection";
import FeatureCard from "../components/FeatureCard";
import Hero from "../components/Hero";
import SectionTitle from "../components/SectionTitle.astro";
import ToolCompareCard from "../components/ToolCompareCard";
import BaseLayout from "../layouts/BaseLayout.astro";
import { articleFromModule, sortArticles } from "../lib/articles";
import type { ArticleModule } from "../lib/articles";
import { toolComparisons } from "../lib/tools";

const articleModules = import.meta.glob<ArticleModule>("../content/articles/*.{md,mdx}", { eager: true });
const articles = sortArticles(
  Object.entries(articleModules).map(([path, articleModule]) => articleFromModule(path, articleModule)),
).slice(0, 3);

const features = [
  {
    icon: "Workflow",
    eyebrow: "Process",
    title: "業務をAIに渡せる形へ分解する",
    description: "人が判断すること、AIが生成すること、ツールで実行すること、最後に確認することを分けて設計します。",
    href: "/prompt-skill-agent/",
  },
  {
    icon: "Terminal",
    eyebrow: "Execution",
    title: "Codexで成果物まで進める",
    description: "相談で止めず、実装、検証、差分確認、コミットまでを作業単位にして開発Agentに任せます。",
    href: "/codex/",
  },
  {
    icon: "Library",
    eyebrow: "Knowledge",
    title: "Obsidianに再利用資産を残す",
    description: "Prompt、Skill、Agent、評価ログをMarkdownで保存し、次の案件や定型業務に戻します。",
    href: "/articles/",
  },
];

const labSystems = [
  "Promptは入力文ではなく、目的、制約、出力形式、評価観点をまとめた作業設計書として扱う。",
  "Skillは繰り返す作業を、手順、禁止事項、検証方法まで含めて保存する。",
  "Agentは権限、ツール、完了条件を明確にし、実行とレビューを分けて使う。",
  "Evalは感覚評価で終わらせず、再現できるチェックリストとして改善サイクルに戻す。",
];
---

<BaseLayout>
  <Hero client:load />

  <section class="section">
    <div class="container">
      <FadeInSection client:visible>
        <SectionTitle
          kicker="Operating model"
          title="AI活用を、単発の相談から業務改善の仕組みへ変える。"
          text="このサイトではAIツールの使い方だけでなく、作った成果物を保存し、検証し、次の作業へ再利用するための運用設計を扱います。"
        />
      </FadeInSection>
      <div class="feature-grid">
        {features.map((feature) => <FeatureCard client:visible {...feature} />)}
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container two-column-grid">
      <FadeInSection client:visible>
        <SectionTitle
          kicker="Lab principle"
          title="AI秘書兼スタッフOSを、現場で回る単位に落とす。"
          text="ChatGPTで考え、Codexで実行し、Obsidianへ保存する。ツールごとの強みを一つの業務フローとして接続します。"
        />
      </FadeInSection>
      <FadeInSection client:visible delay={0.1}>
        <ol class="steps">
          {labSystems.map((item) => <li>{item}</li>)}
        </ol>
      </FadeInSection>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <FadeInSection client:visible>
        <SectionTitle
          kicker="Latest logs"
          title="実践ログ"
          text="AI業務改善の設計、開発Agent活用、ツール比較を、あとから読み返して使える形で記録します。"
        />
      </FadeInSection>
      <div class="article-grid">
        {
          articles.map((article) => (
            <ArticleCard
              client:visible
              title={article.title}
              description={article.description}
              href={article.href}
              category={article.category}
              date={article.dateLabel}
              readTime={article.readTime}
              tags={article.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <FadeInSection client:visible>
        <SectionTitle
          kicker="Tool stack"
          title="用途で選ぶAIツール"
          text="同じAIでも、相談、開発、調査、ナレッジ化では強みが違います。役割を分けるほど運用は安定します。"
        />
      </FadeInSection>
      <div class="tool-grid">
        {toolComparisons.slice(0, 2).map((tool) => <ToolCompareCard client:visible {...tool} />)}
      </div>
    </div>
  </section>

  <div class="container">
    <CTASection
      client:visible
      title="Prompt / Skill / Agent の基本設計から始める"
      text="AI活用を属人的なコツで終わらせず、保存、共有、改善できる運用単位に変えるための入口です。"
      primaryHref="/prompt-skill-agent/"
      primaryLabel="入門ページへ"
      secondaryHref="/tools/"
      secondaryLabel="ツール比較を見る"
    />
  </div>
</BaseLayout>
