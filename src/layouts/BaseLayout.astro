---
import AnimatedBackground from "../components/AnimatedBackground";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { site } from "../lib/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  lang?: string;
  siteName?: string;
  siteTitle?: string;
  locale?: string;
}

const {
  title = site.name,
  description = site.description,
  image = site.ogImage,
  type = "website",
  noindex = false,
  lang = "ja",
  siteName = site.name,
  siteTitle = site.title,
  locale = site.locale,
} = Astro.props;

const pageTitle = title === siteName || title === siteTitle ? siteTitle : `${title} | ${siteName}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImage = new URL(image, site.url).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#070a0d" />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${siteName} OGP image`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <AnimatedBackground client:load />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
