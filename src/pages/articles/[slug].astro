---
import ArticleCard from "../../components/ArticleCard";
import FadeInSection from "../../components/FadeInSection";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { articleFromModule, getArticleDate } from "../../lib/articles";
import type { ArticleEntry, ArticleModule } from "../../lib/articles";

export function getStaticPaths() {
  const articleModules = import.meta.glob<ArticleModule>("../../content/articles/*.{md,mdx}", { eager: true });
  const entries = Object.entries(articleModules)
    .map(([path, articleModule]) => ({
      article: articleFromModule(path, articleModule),
      articleModule,
    }))
    .filter((entry) => !entry.article.draft)
    .sort((a, b) => new Date(getArticleDate(b.article)).getTime() - new Date(getArticleDate(a.article)).getTime());

  return entries.map((entry, index) => ({
    params: { slug: entry.article.slug },
    props: {
      article: entry.article,
      articleModule: entry.articleModule,
      relatedArticles: entries
        .filter((_, relatedIndex) => relatedIndex !== index)
        .slice(0, 2)
        .map((relatedEntry) => relatedEntry.article),
    },
  }));
}

const { article, articleModule, relatedArticles } = Astro.props as {
  article: ArticleEntry;
  articleModule: ArticleModule;
  relatedArticles: ArticleEntry[];
};
const Content = articleModule.default;
---

<BaseLayout title={article.title} description={article.description} type="article">
  <article class="container article-shell">
    <FadeInSection client:load>
      <header class="article-header">
        <a class="text-link article-back-link" href="/articles/">Articlesへ戻る</a>
        <div class="article-card-meta">
          <span>{article.category}</span>
          <time datetime={String(article.pubDate)}>{article.dateLabel}</time>
          {article.readTime && <span>{article.readTime}</span>}
        </div>
        <h1>{article.title}</h1>
        <p class="hero-lede">{article.description}</p>
        <div class="tag-row">
          {article.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>
    </FadeInSection>

    <div class="prose">
      <Content />
    </div>

    {
      relatedArticles.length > 0 && (
        <footer class="article-footer-nav">
          <h2>次に読む</h2>
          <div class="article-grid">
            {relatedArticles.map((related) => (
              <ArticleCard
                client:visible
                title={related.title}
                description={related.description}
                href={related.href}
                category={related.category}
                date={related.dateLabel}
                readTime={related.readTime}
                tags={related.tags}
              />
            ))}
          </div>
        </footer>
      )
    }
  </article>
</BaseLayout>
